<Window x:Class="TripTailorSimple.WPF.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ChatBot IA"
        Height="650"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#E9EEF3">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F172A"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ChatBot IA WPF"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="GitHub Models API + C# / WPF"
                           Margin="0,6,0,0"
                           FontSize="15"
                           Foreground="#94A3B8"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="12"
                BorderBrush="#CBD5E1"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="ChatBox"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="16"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     Height="48"
                     FontSize="16"
                     Padding="12,10"
                     VerticalContentAlignment="Center"
                     BorderBrush="#94A3B8"
                     BorderThickness="1"
                     Background="White"
                     KeyDown="InputBox_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Height="48"
                    Content="Envoyer"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#10B981"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>
        </Grid>

        <Border Grid.Row="3"
                Background="#0EA5E9"
                CornerRadius="10"
                Padding="10">
            <TextBlock x:Name="StatusText"
                       Text="Prêt"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>