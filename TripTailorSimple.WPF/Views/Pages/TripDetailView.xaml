<UserControl x:Class="TripTailorSimple.WPF.Views.Pages.TripDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="#FFF8FAFF">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Button Content="← Retour aux résultats"
                        Width="190"
                        Margin="0,0,0,12"
                        Padding="12,6"
                        Background="White"
                        BorderBrush="#DCE4F2"
                        Command="{Binding BackToResultsCommand}"/>

                <Border Background="White" CornerRadius="16" BorderBrush="#E3E9F4" BorderThickness="1" Padding="16" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,14,0">
                            <TextBlock Text="{Binding Proposal.City}" FontSize="34" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Proposal.Country}" FontSize="18" Foreground="#6D7486"/>
                            <TextBlock Text="{Binding Proposal.Description}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="12" ClipToBounds="True">
                            <Image Source="{Binding Proposal.ImageUrl}" Height="170" Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </Border>

                <UniformGrid Columns="3" Margin="0,0,0,14">
                    <Border Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel><TextBlock Text="Vol" Foreground="#657089"/><TextBlock Text="{Binding Proposal.EstimatedFlightPrice, StringFormat={}{0} €}" FontSize="22" FontWeight="Bold"/></StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel><TextBlock Text="Hôtel" Foreground="#657089"/><TextBlock Text="{Binding Proposal.EstimatedHotelPrice, StringFormat={}{0} €}" FontSize="22" FontWeight="Bold"/></StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel><TextBlock Text="Activités" Foreground="#657089"/><TextBlock Text="{Binding Proposal.EstimatedActivityPrice, StringFormat={}{0} €}" FontSize="22" FontWeight="Bold"/></StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Prévisions météo (Open-Meteo API + fallback local)" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding Forecast}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Date}" Width="110" FontWeight="SemiBold"/>
                                            <Border Background="#EEF3FF" CornerRadius="8" Padding="8,3">
                                                <TextBlock Text="{Binding Summary}"/>
                                            </Border>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="12" Padding="12" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Activités" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Payantes" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding Proposal.PaidActivities}" Margin="0,4,0,8"/>
                            <TextBlock Text="Gratuites" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding Proposal.FreeActivities}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="White" BorderBrush="#E3E9F4" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Planning jour par jour" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding Proposal.SuggestedPlan}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EDF1F8" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DayNumber, StringFormat=Jour {0}}" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="{Binding Morning, StringFormat=🌅 Matin : {0}}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Afternoon, StringFormat=🌇 Après-midi : {0}}" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding Evening, StringFormat=🌙 Soir : {0}}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <WrapPanel Margin="0,0,0,2">
                    <Button Content="Vols" Command="{Binding OpenLinkCommand}" CommandParameter="{Binding Proposal.FlightLink}" Margin="0,0,8,8" Padding="12,6"/>
                    <Button Content="Hôtels" Command="{Binding OpenLinkCommand}" CommandParameter="{Binding Proposal.HotelLink}" Margin="0,0,8,8" Padding="12,6"/>
                    <Button Content="Activités" Command="{Binding OpenLinkCommand}" CommandParameter="{Binding Proposal.ActivitiesLink}" Margin="0,0,8,8" Padding="12,6"/>
                    <Button Content="Wikipedia" Command="{Binding OpenLinkCommand}" CommandParameter="{Binding Proposal.WikipediaLink}" Margin="0,0,8,8" Padding="12,6"/>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
